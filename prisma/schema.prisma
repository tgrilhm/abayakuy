generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id         String   @id @default(uuid()) @db.Uuid
  kode       String?  @unique
  nama       String?  // Display name
  brand      String?
  bahan      String?  // Material / Fabric
  ukuran     String[] // Sizes array e.g. ["S", "M", "L"]
  warna      String?  // Color (single text)
  harga      Float?   // Price
  kategori   String?  // Category e.g. "Abaya Hitam", "Abaya Warna"
  deskripsi  String?  // Long description for product detail page
  stok       Int?     // Stock quantity
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  media Media[] // Multiple photos/videos

  @@map("products")
}

model Media {
  id         String   @id @default(uuid()) @db.Uuid
  url        String   // Public URL from Supabase Storage
  type       String   // "image" or "video"
  order      Int      @default(0) // Display order
  product_id String   @db.Uuid
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  @@map("media")
}
