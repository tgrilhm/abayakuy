generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
model Product {
  id         String   @id @default(uuid()) @db.Uuid
  code       String   @unique
  name       String
  brand      String
  size       String
  price      Float
  image_url  String
  created_at DateTime @default(now())

  @@map("products")
}
