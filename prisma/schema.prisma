generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

enum Kategori {
  Outer_Abaya    @map("Outer Abaya")
  Instant_Abaya  @map("Instant Abaya")
  Luxe_Kaftan    @map("Luxe Kaftan")
  Luxe_Chiffon   @map("Luxe Chiffon")
  Velvet_Abaya   @map("Velvet Abaya")
}

enum Ukuran {
  L
  XL
  XXL        @map("2XL")
  XXXL       @map("3XL")
  XXXXL      @map("4XL")
  Free_Size  @map("Free Size")
}

enum Bahan {
  Premium_Harrer  @map("Premium Harrer")
  Tiktok          @map("Tiktok")
  Harrer_Suudi    @map("Harrer Suudi")
  Kursa           @map("Kursa")
  Siffon          @map("Siffon")
  Harrer          @map("Harrer")
  Velvet_Bludru   @map("Velvet Bludru")
  Crepe           @map("Crepe")
  Satin           @map("Satin")
}

enum Warna {
  Hitam         @map("Hitam")
  Krem          @map("Krem")
  Coffe         @map("Coffe")
  Mint          @map("Mint")
  Biru          @map("Biru")
  Abu_abu       @map("Abu-abu")
  Merah         @map("Merah")
  Coklat        @map("Coklat")
  Putih         @map("Putih")
  Kuning        @map("Kuning")
  Ungu          @map("Ungu")
  Hijau         @map("Hijau")
  Hijau_Botol   @map("Hijau Botol")
  Broken_White  @map("Broken White")
  Emerald       @map("Emerald")
}

model Product {
  id               String     @id @default(uuid()) @db.Uuid
  kode             String?    @unique
  nama             String?    // Display name
  brand            String?
  link             String?    // Product-specific Shopee URL
  bahan            Bahan?     // Material / Fabric (enum)
  ukuran           Ukuran[]   // Sizes enum array
  warna            Warna[]    // Colors (enum array)
  harga            Float?     // Price
  kategori         Kategori?  // Category enum
  deskripsi        String?    // Long description
  isTrending       Boolean    @default(false) // Show on Trending Now page
  isSale           Boolean    @default(false) // Show on Sale page
  isHeroFeatured   Boolean    @default(false) // Show name on Home hero image
  isVisible        Boolean    @default(true)  // Show in catalog / storefront
  isAvailable      Boolean    @default(true)  // Availability status (Sold Out if false)
  created_at       DateTime   @default(now())
  updated_at       DateTime   @updatedAt

  media Media[]

  @@index([kategori])
  @@index([isTrending])
  @@index([isSale])
  @@index([isVisible])
  @@index([created_at])
  @@map("products")
}

model Media {
  id         String   @id @default(uuid()) @db.Uuid
  url        String   // Public URL from Supabase Storage
  type       String   // "image" or "video"
  order      Int      @default(0)
  product_id String   @db.Uuid
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  @@map("media")
}
